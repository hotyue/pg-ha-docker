# ==============================================================================
# 🚀 PostgreSQL 高可用集群 (Patroni + Etcd + HAProxy) 环境变量配置参考
# ==============================================================================
# ⚠️ 注意: 
# 1. 请将此文件复制并重命名为 `.env`，然后根据实际情况修改变量。
# 2. 强烈建议直接使用项目中提供的 install.sh 脚本，它会自动计算并生成准确的 .env 文件。
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 当前节点身份配置 (Node Identity)
# ------------------------------------------------------------------------------
# 当前节点的编号 (必须是 1, 2 或 3)
NODE_ID=1
# 当前节点的公网/内网 IP (支持 IPv4 或 [IPv6])
CURRENT_IP=192.168.1.101

# ------------------------------------------------------------------------------
# 2. 集群全局拓扑配置 (Cluster Topology)
# ------------------------------------------------------------------------------
# 所有节点的 IP 列表，用于 Etcd 组网和 HAProxy 路由分发
# 必须使用一致的 IP 格式，纯 IPv6 地址必须使用方括号，如 [2a0b:4e07:8::1]
NODE1_IP=192.168.1.101
NODE2_IP=192.168.1.102
NODE3_IP=192.168.1.103

# ------------------------------------------------------------------------------
# 3. 集群安全凭证 (Security Credentials)
# ------------------------------------------------------------------------------
# 数据库超级管理员密码 (postgres 用户的密码)
PG_ROOT_PASSWORD=YourSuperSecretRootPassword
# 数据库底层流复制密码 (replicator 用户的密码，供节点间同步数据使用)
PG_REPL_PASSWORD=YourSuperSecretReplPassword

# ------------------------------------------------------------------------------
# 4. 🌐 跨国/高延迟网络自适应调优参数 (Network Tuning & Consensus)
# ------------------------------------------------------------------------------
# ⚠️ 极其重要: 以下五个参数必须在集群的所有三个节点中保持【绝对一致】！
# 如果参数不一致，将导致集群产生严重的脑裂 (Split-Brain) 和无休止的篡权选举。
# 默认值参考 (以下为适合跨省/中等延迟 150ms 左右的稳健推荐值)：

# Etcd 选举超时时间 (毫秒)。推荐：内网 5000，跨省 10000，跨洋跨国 20000
ETCD_ELECTION_TIMEOUT=10000

# Patroni 主库全局锁的存活时间 (秒)。推荐：内网 30，跨省 60，跨洋跨国 90
PATRONI_TTL=60

# Patroni 正常情况下每隔多久去 Etcd 更新一次锁 (秒)。推荐：内网 10，跨省 10，跨洋跨国 20
PATRONI_LOOP_WAIT=10

# Patroni 遇到网络抖动时的重试宽容时间 (秒)。推荐：内网 10，跨省 30，跨洋跨国 60
PATRONI_RETRY_TIMEOUT=30

# HAProxy 对后端节点的健康检查间隔 (毫秒)。推荐：内网 2000，跨省 4000，跨洋跨国 5000
HA_INTER_TIME=4000